{
	"name": "@connect-utah-today/website",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dotenvx": "dotenvx",
		"dev": "dotenvx run --convention=nextjs -- next dev",
		"build": "SKIP_YARN_COREPACK_CHECK=0 dotenvx run -f .env.production -- next build --experimental-build-mode compile",
		"start": "dotenvx run --convention=nextjs -- next start",
		"check-types": "tsc --noEmit",
		"generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
		"generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
		"encrypt-env": "cp .env.production.local .env.production && dotenvx encrypt -f .env.production"
	},
	"dependencies": {
		"@connect-utah-today/api": "*",
		"@connect-utah-today/utils": "*",
		"@dotenvx/dotenvx": "^1.61.0",
		"@payloadcms/db-postgres": "^3.76.1",
		"@payloadcms/next": "^3.76.1",
		"@payloadcms/richtext-lexical": "^3.76.1",
		"cross-env": "^10.1.0",
		"graphql": "^16.12.0",
		"lucide": "^1.7.0",
		"lucide-react": "^0.563.0",
		"next": "^16.1.6",
		"payload": "^3.76.1",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-markdown": "^10.1.0",
		"react-select": "^5.10.2",
		"sharp": "^0.34.5"
	},
	"devDependencies": {
		"@connect-utah-today/tsconfig": "*",
		"@types/node": "25.2.3",
		"@types/react": "^19.2.14",
		"postcss": "^8.5.6",
		"sass": "^1.97.3",
		"typescript": "^5.9.3"
	},
	"packageManager": "npm@11.7.0"
}
